# PostgreSQL Database URL for Prisma schema operations
# Replace placeholders with your database credentials (e.g. postgres:securepass@localhost:5432/db)
DATABASE_URL="postgresql://postgres:postgres_secure_pass_123@db:5432/smart_health?schema=public"

# JSON Web Token Secret Key used for signing session profiles
JWT_SECRET="generate_a_secure_random_string_here_for_sessions"

# Local port configuration for Express REST server
PORT=5000
